---
import Layout from '../layouts/Layout.astro';
import Header from '../components/ui/Header.astro';
import Footer from '../components/sections/Footer.astro';
import TinaIsland from '@tinacms/astro/TinaIsland.astro';
import HomeBody from '../components/islands/HomeBody.astro';
import { getHome } from '../lib/tina/data';
import { islands } from '../lib/tina/islands';

const page = await getHome();
const data = page.data?.paginas;
---

<Layout title={data?.seo?.metaTitle || data?.title}>
	<Header />
	<TinaIsland name="home" wrapper={islands.home.wrapper} params={{}} primary>
		<HomeBody data={data} />
	</TinaIsland>
	<Footer />
</Layout>
