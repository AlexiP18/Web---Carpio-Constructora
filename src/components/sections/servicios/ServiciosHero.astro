---
import { Icon } from "astro-icon/components";
import ServiciosLista from './ServiciosLista.astro';

// Background image from public folder
const serviciosHeroImage = '/images/services/ServiciosHero.webp';
---

<section id="serviciosHeroTrack" class="relative min-h-[250vh] bg-gradient-to-br from-gray-900 via-slate-800 to-gray-900 overflow-visible">
  <!-- Pinned Sticky Container -->
  <div class="sticky top-0 h-screen w-full flex items-center justify-center overflow-hidden z-10">
    <!-- Background Image -->
    <div class="absolute inset-0 w-full h-full">
      <img 
        src={serviciosHeroImage} 
        alt="Servicios Hero Background" 
        class="w-full h-full object-cover opacity-35"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-gray-900/60 via-slate-900/80 to-gray-950/90"></div>
    </div>
    
    <!-- Background decorations -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-20 left-20 w-60 h-60 bg-[#103646]/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-20 right-20 w-40 h-40 bg-[#D79528]/15 rounded-full blur-2xl"></div>
      <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-80 h-80 bg-[#103646]/5 rounded-full blur-3xl"></div>
    </div>

    <!-- Interactive Scroll Content Container -->
    <div class="max-w-7xl mx-auto px-6 relative z-10 w-full flex flex-col items-center justify-center">
      
      <!-- Permanent Main Header Section (Does NOT change or fade) -->
      <div class="max-w-4xl mx-auto text-center mb-8 shrink-0">
        <h1 class="text-4xl lg:text-6xl xl:text-7xl font-bold text-white leading-tight mb-4">
          Nuestros <span class="text-[#D79528]">Servicios</span>
        </h1>
        
        <p class="text-base sm:text-lg lg:text-xl text-white/90 leading-relaxed max-w-3xl mx-auto font-light">
          Ofrecemos soluciones constructivas integrales con los más altos estándares de calidad para satisfacer todas tus necesidades.
        </p>
      </div>

      <!-- Dynamic Content Swap Container (Chips -> Cards) -->
      <div class="relative w-full max-w-7xl min-h-[360px] flex items-center justify-center">
        
        <!-- Stage 1: Feature Chips -->
        <div id="servicesChipsContainer" class="w-full max-w-4xl mx-auto transition-all duration-500 ease-out">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="service-chip bg-white/10 backdrop-blur-md border border-white/20 rounded-3xl p-6 hover:bg-white/15 transition-all duration-300 shadow-lg group">
              <div class="flex flex-col items-center justify-center text-center gap-3">
                <div class="w-12 h-12 bg-gradient-to-br from-[#103646] to-[#103646]/80 rounded-2xl flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300">
                  <Icon name="ph:buildings-fill" class="w-6 h-6 text-white" />
                </div>
                <div>
                  <h3 class="text-lg font-bold text-white mb-1">Construcción</h3>
                  <p class="text-white/70 text-sm">Residencial y comercial</p>
                </div>
              </div>
            </div>
            
            <div class="service-chip bg-white/10 backdrop-blur-md border border-white/20 rounded-3xl p-6 hover:bg-white/15 transition-all duration-300 shadow-lg group">
              <div class="flex flex-col items-center justify-center text-center gap-3">
                <div class="w-12 h-12 bg-gradient-to-br from-[#D79528] to-[#D79528]/80 rounded-2xl flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300">
                  <Icon name="ph:hammer-fill" class="w-6 h-6 text-white" />
                </div>
                <div>
                  <h3 class="text-lg font-bold text-white mb-1">Remodelación</h3>
                  <p class="text-white/70 text-sm">Modernización completa</p>
                </div>
              </div>
            </div>
            
            <div class="service-chip bg-white/10 backdrop-blur-md border border-white/20 rounded-3xl p-6 hover:bg-white/15 transition-all duration-300 shadow-lg group">
              <div class="flex flex-col items-center justify-center text-center gap-3">
                <div class="w-12 h-12 bg-[#103646] rounded-2xl flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300">
                  <Icon name="ph:pencil-ruler-fill" class="w-6 h-6 text-white" />
                </div>
                <div>
                  <h3 class="text-lg font-bold text-white mb-1">Diseño Arquitectónico</h3>
                  <p class="text-white/70 text-sm">Proyectos personalizados</p>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Stage 2: Detailed Cards (ServiciosLista) -->
        <div id="servicesListContainer" class="absolute inset-0 w-full flex items-center justify-center opacity-0 pointer-events-none transition-all duration-500 ease-out">
          <ServiciosLista />
        </div>

      </div>

    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const track = document.getElementById('serviciosHeroTrack');
    const chipsContainer = document.getElementById('servicesChipsContainer');
    const listContainer = document.getElementById('servicesListContainer');

    if (!track || !chipsContainer || !listContainer) return;

    function updateHeroScroll() {
      if (!track || !chipsContainer || !listContainer) return;
      const rect = track.getBoundingClientRect();
      const trackHeight = track.offsetHeight - window.innerHeight;
      
      if (trackHeight <= 0) return;

      // Progress from 0 to 1 as track scrolls through viewport
      const progress = Math.min(Math.max(-rect.top / trackHeight, 0), 1);

      // Phase 1 (0 to 0.20): Chips visible, cards hidden
      if (progress < 0.20) {
        chipsContainer.style.opacity = '1';
        chipsContainer.style.transform = 'translateY(0px) scale(1)';
        chipsContainer.style.pointerEvents = 'auto';

        listContainer.style.opacity = '0';
        listContainer.style.transform = 'translateY(30px) scale(0.95)';
        listContainer.style.pointerEvents = 'none';
      } 
      // Phase 2 (0.20 to 0.55): Chips fade out & slide down/up, Cards fade in & slide up into place
      else if (progress >= 0.20 && progress < 0.55) {
        const t = (progress - 0.20) / 0.35; // Normalized 0 to 1

        chipsContainer.style.opacity = `${Math.max(1 - t * 1.5, 0)}`;
        chipsContainer.style.transform = `translateY(${t * 30}px) scale(${1 - t * 0.05})`;
        chipsContainer.style.pointerEvents = t > 0.5 ? 'none' : 'auto';

        listContainer.style.opacity = `${Math.min(t * 1.3, 1)}`;
        listContainer.style.transform = `translateY(${Math.max(30 - t * 30, 0)}px) scale(${0.95 + t * 0.05})`;
        listContainer.style.pointerEvents = t > 0.5 ? 'auto' : 'none';
      } 
      // Phase 3 (0.55 to 1.0): Cards fully visible right under title/description & pinned for comfortable viewing before scrolling to next section
      else {
        chipsContainer.style.opacity = '0';
        chipsContainer.style.pointerEvents = 'none';

        listContainer.style.opacity = '1';
        listContainer.style.transform = 'translateY(0px) scale(1)';
        listContainer.style.pointerEvents = 'auto';
      }
    }

    let ticking = false;
    window.addEventListener('scroll', function() {
      if (!ticking) {
        window.requestAnimationFrame(function() {
          updateHeroScroll();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    // Initial check
    updateHeroScroll();
  });
</script>
