---
interface Props {
  videoUrl: string;
  title?: string;
  description?: string;
  poster?: string;
  projectName?: string;
  projectDescription?: string;
}

const { 
  videoUrl, 
  title = "Tour Virtual del Proyecto",
  description = "Explora cada detalle de este proyecto a través de nuestro tour virtual",
  poster,
  projectName,
  projectDescription
} = Astro.props;

// Detectar si es URL de Cloudinary o local
const isCloudinaryUrl = videoUrl.includes('cloudinary.com') || videoUrl.includes('res.cloudinary');

// Generar URLs optimizadas para Cloudinary
let videoMp4 = videoUrl;
let videoWebm = videoUrl;
let videoPoster = poster || '';

if (isCloudinaryUrl && videoUrl.includes('/upload/')) {
  // Transformaciones de Cloudinary para optimización
  videoMp4 = videoUrl.replace('/upload/', '/upload/f_mp4,vc_h264/');
  videoWebm = videoUrl.replace('/upload/', '/upload/f_webm,vc_vp9/');
  // Poster del primer frame
  if (!poster) {
    videoPoster = videoUrl.replace('/upload/', '/upload/so_0,f_jpg,w_1280/').replace(/\.(mov|mp4|webm|avi)$/i, '.jpg');
  }
}
---

<section class="relative w-full py-16 md:py-24 bg-gradient-to-b from-gray-50 to-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header Section (Solo si no hay proyecto/descripción específica o para dar contexto superior) -->
    {(!projectName) && (
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-4">
          {title}
        </h2>
        {description && (
          <p class="text-lg md:text-xl text-gray-600 max-w-2xl mx-auto">
            {description}
          </p>
        )}
      </div>
    )}

    <!-- Video Container -->
    <div class="relative max-w-6xl mx-auto">
      <!-- Decorative background -->
      <div class="absolute -inset-4 bg-gradient-to-r from-blue-500/10 to-green-500/10 rounded-3xl blur-2xl"></div>
      
      <!-- Video wrapper with shadow and border -->
      <div class="relative bg-[#050505] rounded-2xl shadow-2xl overflow-hidden border border-gray-800 group">
        <!-- Aspect ratio container -->
        <div class="relative w-full video-container" style="padding-bottom: 56.25%;"> <!-- 16:9 aspect ratio -->
          {isCloudinaryUrl ? (
            <video 
              id="project-video"
              class="absolute top-0 left-0 w-full h-full object-cover"
              controls={false}
              autoplay
              loop
              muted
              playsinline
              preload="metadata"
              poster={videoPoster}
            >
              <source src={videoWebm} type="video/webm">
              <source src={videoMp4} type="video/mp4">
              <p>
                Tu navegador no soporta la reproducción de video. 
                <a href={videoMp4} download style="color: #2563eb; text-decoration: underline;">
                  Descarga el video aquí
                </a>
              </p>
            </video>
          ) : (
            <video 
              id="project-video"
              class="absolute top-0 left-0 w-full h-full object-cover"
              controls={false}
              autoplay
              loop
              muted
              playsinline
              preload="metadata"
            >
              <source src={videoUrl} type="video/mp4">
              <source src={videoUrl} type="video/quicktime">
              <source src={videoUrl.replace('.mov', '.webm')} type="video/webm">
              
              <p>
                Tu navegador no soporta la reproducción de video. 
                <a href={videoUrl} download style="color: #2563eb; text-decoration: underline;">
                  Descarga el video aquí
                </a>
              </p>
            </video>
          )}

          <!-- SVG Mask for the 3 columns (Window Effect) -->
          <svg class="absolute inset-0 w-full h-full pointer-events-none z-10" preserveAspectRatio="none">
            <defs>
              <mask id="windowMask">
                <rect width="100%" height="100%" fill="white" />
                <!-- 3 pill-shaped windows -->
                <!-- Left -->
                <rect x="2%" y="4%" width="30.66%" height="92%" rx="30" fill="black" />
                <!-- Center -->
                <rect x="34.66%" y="4%" width="30.66%" height="92%" rx="30" fill="black" />
                <!-- Right -->
                <rect x="67.33%" y="4%" width="30.66%" height="92%" rx="30" fill="black" />
              </mask>
            </defs>
            <!-- Black overlay covering everything except the windows -->
            <rect width="100%" height="100%" fill="#0a0a0a" mask="url(#windowMask)" />
          </svg>

          <!-- Interactive Content Overlay -->
          <div 
            id="video-overlay" 
            class="absolute inset-0 grid grid-cols-1 md:grid-cols-3 transition-opacity duration-500 z-20 pointer-events-none"
            style="padding: 4% 2%; column-gap: 2%;"
          >
            <!-- Column 1 (Left): Contact Info & Button -->
            <div class="flex flex-col justify-end p-6 md:p-8 text-left text-white h-full relative z-20 pointer-events-auto">
              <div class="flex flex-col items-start gap-4">
                <p class="text-white font-medium text-sm md:text-base drop-shadow-md leading-relaxed max-w-[200px]">
                  ¿Te interesa este proyecto? Contáctanos para más información
                </p>
                <a 
                  href="/contacto" 
                  class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-semibold text-xs md:text-sm rounded-full transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl"
                >
                  Solicitar Información
                </a>
              </div>
            </div>

            <!-- Column 2 (Center): Logo Symbol -->
            <div class="flex items-center justify-center p-6 h-full relative z-20 pointer-events-auto">
              <button 
                id="play-fullscreen-btn"
                class="w-24 h-24 md:w-32 md:h-32 rounded-full flex flex-col items-center justify-center gap-2 shadow-2xl transition-all duration-300 hover:scale-110 group focus:outline-none"
                aria-label="Reproducir video en pantalla completa"
              >
                <!-- Usamos solo el simbolo de la web -->
                <img 
                  src="/icons/LogoCarpio.svg" 
                  alt="Simbolo Carpio" 
                  class="w-16 md:w-20 h-auto drop-shadow-[0_0_15px_rgba(255,255,255,0.5)] brightness-0 invert transition-transform duration-500 group-hover:rotate-12" 
                />
              </button>
            </div>

            <!-- Column 3 (Right): Project Title & Description -->
            <div class="flex flex-col justify-end p-6 md:p-8 text-left md:text-right text-white h-full relative z-20 pointer-events-auto">
              <div class="flex flex-col items-start md:items-end w-full">
                <span class="text-xs uppercase tracking-widest text-blue-400 font-bold mb-2">Proyecto Destacado</span>
                <h3 class="text-3xl md:text-4xl lg:text-5xl font-black tracking-tighter uppercase drop-shadow-lg text-white mb-3 leading-tight">
                  {projectName || title}
                </h3>
                {(projectDescription || description) && (
                  <p class="text-xs md:text-sm text-gray-200/90 max-w-xs drop-shadow font-light leading-relaxed">
                    {projectDescription || description}
                  </p>
                )}
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>

  </div>
</section>

<style>
  /* SVG Mask for responsive pill shapes */
  @media (max-width: 768px) {
    /* En móvil, ajustamos el grid a una sola columna o ajustamos el mask si se necesita, 
       pero por ahora la máscara SVG se estirará manteniendo proporciones. 
       Para que se vea bien en móvil (1 columna), podríamos redefinir el SVG, 
       pero la instrucción parece enfocarse en la vista de escritorio (3 columnas). */
  }
  
  video {
    max-width: 100%;
    height: auto;
    object-fit: cover;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const video = document.getElementById('project-video') as HTMLVideoElement;
    const overlay = document.getElementById('video-overlay');
    const playBtn = document.getElementById('play-fullscreen-btn');
    const svgMask = document.querySelector('svg.absolute');

    if (!video || !overlay || !playBtn || !svgMask) return;

    // Al hacer click en el botón del logo central
    playBtn.addEventListener('click', () => {
      // Reiniciar video y habilitar controles nativos si se desea
      video.currentTime = 0;
      video.muted = false; // Desmutear para pantalla completa
      video.controls = true; // Mostrar controles para poder salir o pausar en FS
      
      // Ocultar la estructura de ventanas
      overlay.classList.add('opacity-0', 'pointer-events-none');
      svgMask.classList.add('opacity-0', 'pointer-events-none');

      // Reproducir
      video.play().catch(err => console.log('Playback error:', err));

      // Solicitar pantalla completa
      if (video.requestFullscreen) {
        video.requestFullscreen();
      } else if ((video as any).webkitRequestFullscreen) {
        (video as any).webkitRequestFullscreen();
      } else if ((video as any).msRequestFullscreen) {
        (video as any).msRequestFullscreen();
      }
    });

    // Escuchar el evento de salida de pantalla completa para restaurar la vista si se desea
    const handleFullscreenChange = () => {
      const isFullscreen = document.fullscreenElement || (document as any).webkitFullscreenElement;
      if (!isFullscreen) {
        // Restaurar estado ventana
        video.muted = true;
        video.controls = false;
        overlay.classList.remove('opacity-0', 'pointer-events-none');
        svgMask.classList.remove('opacity-0', 'pointer-events-none');
        // Continuar reproduciendo en bucle de fondo
        video.play().catch(e => console.log(e));
      }
    };

    document.addEventListener('fullscreenchange', handleFullscreenChange);
    document.addEventListener('webkitfullscreenchange', handleFullscreenChange);
  });
</script>

