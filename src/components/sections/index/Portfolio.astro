---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import MosaicSecondaryBg from "../../ui/MosaicSecondaryBg.astro";
import MobileProjectsStack from "./MobileProjectsStack";

export interface Props {
  selectedProjects?: string[];
}

const { selectedProjects } = Astro.props;

// Fetch projects
const allProjects = await getCollection("proyectos");

// Filter projects if selectedProjects is specified, otherwise take first 6
let projects = allProjects;
if (selectedProjects && selectedProjects.length > 0) {
  const filtered = selectedProjects
    .map(slugOrTitle => allProjects.find(p => p.slug === slugOrTitle || p.data.title.toLowerCase().includes(slugOrTitle.toLowerCase())))
    .filter((p): p is typeof allProjects[0] => Boolean(p));
  if (filtered.length > 0) {
    projects = filtered;
  } else {
    projects = allProjects.slice(0, 6);
  }
} else {
  projects = allProjects.slice(0, 6);
}

const projectsForMobile = projects.map(p => ({
  slug: p.slug,
  title: p.data.title,
  description: p.data.description,
  tags: p.data.tags || [],
  backgroundImage: p.data.backgroundImage,
  images: p.data.images || []
}));
---

<!-- Portfolio Section - Premium Sliding Accordion Panels -->
<section class="w-full py-16 lg:py-24 relative overflow-hidden bg-[#D79528]">
  <!-- SVG Background -->
  <div class="absolute inset-0 w-full h-full pointer-events-none opacity-100">
    <MosaicSecondaryBg />
  </div>

  <div class="max-w-7xl mx-auto px-6 relative z-10 mb-12">
    <!-- Header Section -->
    <div class="text-center" data-aos="fade-up" data-aos-duration="800">
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full border border-white/15 mb-6">
        <div class="w-2 h-2 bg-[#D79528] rounded-full animate-ping"></div>
        <span class="font-semibold text-sm text-white tracking-wider uppercase">
          Nuestros Proyectos
        </span>
      </div>
      <h2 class="font-bold text-4xl lg:text-6xl text-white mb-6 font-heading">
        Calidad en cada detalle
      </h2>
      <p class="text-lg lg:text-xl text-white/70 max-w-2xl mx-auto font-body">
        Explora nuestras obras maestras. Pasa el cursor sobre cada columna para descubrir los detalles del proyecto.
      </p>
    </div>
  </div>

  <!-- Mobile Version: Interactive Scroll Stacking Card Effect (lg:hidden) -->
  <MobileProjectsStack client:load projects={projectsForMobile} />

  <!-- Desktop Version: Sliding Panels Container (hidden lg:block) -->
  <div class="hidden lg:block w-full max-w-[1400px] mx-auto px-8 relative z-10" data-aos="fade-up" data-aos-delay="200">
    <div class="accordion-container flex flex-row w-full gap-4 h-[650px] overflow-hidden min-h-[500px]">
      {projects.map((project) => {
        // Determine tag icon
        const firstTag = project.data.tags?.[0] || "Proyecto";
        let iconName = "ph:briefcase";
        
        if (
          firstTag.toLowerCase().includes("residencial") || 
          firstTag.toLowerCase().includes("unifamiliar") || 
          firstTag.toLowerCase().includes("casa")
        ) {
          iconName = "ph:house";
        } else if (
          firstTag.toLowerCase().includes("retail") || 
          firstTag.toLowerCase().includes("comercial") || 
          firstTag.toLowerCase().includes("local")
        ) {
          iconName = "ph:storefront";
        } else if (
          firstTag.toLowerCase().includes("conjunto") || 
          firstTag.toLowerCase().includes("multifamiliar") || 
          firstTag.toLowerCase().includes("edificio")
        ) {
          iconName = "ph:buildings";
        }

        return (
          <a
            href={`/proyecto/${project.slug}`}
            class="accordion-item group relative flex-1 h-full overflow-hidden rounded-2xl cursor-pointer shadow-lg hover:shadow-2xl transition-all duration-700 ease-out border border-white/5 hover:border-white/20"
            style={`background-image: url('${project.data.backgroundImage}'); background-size: cover; background-position: center;`}
          >
            {/* Elegant background overlay gradient (always active, transitions to brand color on hover) */}
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent group-hover:from-black/95 group-hover:via-[#103646]/75 transition-all duration-700 pointer-events-none z-10"></div>

            {/* Vertical Title (Shown on desktop when collapsed, with semi-transparent background card for readability) */}
            <div class="hidden lg:flex absolute inset-0 items-center justify-center pointer-events-none transition-all duration-500 ease-out z-15 opacity-100 group-hover:opacity-0 group-hover:-translate-y-8">
              <div class="bg-black/55 backdrop-blur-sm py-8 px-4 rounded-full border border-white/10 shadow-xl flex items-center justify-center min-w-[54px] max-h-[85%]">
                <span class="text-white text-base lg:text-lg font-black uppercase tracking-widest select-none vertical-text">
                  {project.data.title}
                </span>
              </div>
            </div>

            {/* Horizontal content (visible on hover on desktop) */}
            <div class="absolute inset-0 p-6 lg:p-10 flex flex-col justify-end text-white z-20 transition-all duration-700 ease-out translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100">
              
              {/* Category Tag / Chip with Icon */}
              <div class="flex items-center gap-2 px-3 py-1.5 bg-[#D79528] text-white text-xs font-black rounded-full uppercase tracking-wider shadow-md w-fit mb-4 select-none">
                <Icon name={iconName} class="w-4 h-4" />
                <span>{firstTag}</span>
              </div>
              
              {/* Project Title */}
              <h3 class="font-bold text-2xl lg:text-3xl text-white mb-2 leading-tight drop-shadow-md font-heading">
                {project.data.title}
              </h3>

              {/* Project Description */}
              <p class="text-white/80 text-sm leading-relaxed max-w-md mb-6 drop-shadow-sm font-body">
                {project.data.description}
              </p>

              {/* View Project Link */}
              <span class="inline-flex items-center gap-2 text-[#D79528] font-bold text-sm hover:text-white transition-colors duration-300 w-fit group/btn">
                <span>Ver Proyecto</span>
                <Icon name="ph:arrow-right-bold" class="w-4 h-4 group-hover/btn:translate-x-1.5 transition-transform duration-300" />
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </div>

  <!-- Bottom CTA Button -->
  <div class="text-center mt-16 px-6" data-aos="fade-up" data-aos-delay="300">
    <a 
      href="/todos-proyectos"
      class="inline-flex items-center gap-3 px-8 py-4 bg-white text-[#103646] font-bold rounded-full shadow-xl hover:shadow-2xl hover:scale-105 transition-all duration-300"
    >
      <span>Ver todos los proyectos</span>
      <Icon name="ph:arrow-right-bold" class="w-5 h-5" />
    </a>
  </div>
</section>

<style>
  /* Base Accordion Item transition */
  .accordion-item {
    transition: flex 0.75s cubic-bezier(0.25, 1, 0.35, 1), border-color 0.5s ease;
  }

  /* Vertical upright text layout */
  .vertical-text {
    writing-mode: vertical-rl;
    text-orientation: upright;
    letter-spacing: 0.2em;
    text-align: center;
    line-height: 1.2;
  }

  /* Desktop hover interaction: Expand hovered card and contract others */
  @media (min-width: 1024px) {
    .accordion-container:hover .accordion-item {
      flex: 0.6;
    }
    
    .accordion-container .accordion-item:hover {
      flex: 5.5;
    }
  }

  /* Mobile/Tablet: Stack cards vertically with constant display */
  @media (max-width: 1023px) {
    .accordion-item {
      flex: none !important;
      width: 100% !important;
    }
  }
</style>
